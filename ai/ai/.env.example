# YEJI AI Server 환경 변수
# 최종 수정: 2026-01-30

# =============================================================================
# 서버 설정
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# vLLM 설정 (필수)
# =============================================================================
# 프로덕션: AWS GPU Elastic IP
VLLM_BASE_URL=http://13.125.68.166:8001
VLLM_MODEL=tellang/yeji-8b-rslora-v7-AWQ
VLLM_MAX_TOKENS=2048
VLLM_TEMPERATURE=0.7
VLLM_TOP_P=0.9

# =============================================================================
# HuggingFace (모델 다운로드용)
# =============================================================================
HF_TOKEN=your_huggingface_token_here

# =============================================================================
# 백엔드 연동
# =============================================================================
BACKEND_URL=http://localhost:8081

# =============================================================================
# CORS 설정
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","https://i14a605.p.ssafy.io"]

# =============================================================================
# 티키타카 설정
# =============================================================================
TIKITAKA_MAX_TURNS=10
TIKITAKA_QUESTION_COUNT=2

# =============================================================================
# GPT-5-mini 설정 (채팅용 LLM 전환)
# =============================================================================
# true: GPT-5-mini 사용 (OPENAI_API_KEY 필요)
# false: 8B vLLM만 사용
USE_GPT5MINI_FOR_CHAT=false

# OpenAI API 설정 (USE_GPT5MINI_FOR_CHAT=true일 때 필요)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# =============================================================================
# 테스트/디버그 설정
# =============================================================================
SKIP_VALIDATION=false

# =============================================================================
# GPU 필터 설정 (선택적 - L4 GPU 배포 시 활성화)
# =============================================================================
# GPU 필터 전체 활성화
GPU_FILTER_ENABLED=false
GPU_DEVICE=cuda:0

# Prompt Guard 설정 (악성 프롬프트 탐지)
GUARD_MODEL=meta-llama/Llama-Prompt-Guard-2-86M
GUARD_THRESHOLD=0.8
GUARD_TIMEOUT=1.0
GUARD_MODE=block
GUARD_REQUIRED=false

# Intent Classifier 설정 (임베딩 기반 의도 분류)
INTENT_EMBEDDING_MODEL=Alibaba-NLP/gte-multilingual-base
INTENT_EMBEDDING_THRESHOLD=0.7
INTENT_EMBEDDING_TIMEOUT=0.5
INTENT_EMBEDDING_MODE=block
INTENT_EMBEDDING_REQUIRED=false
