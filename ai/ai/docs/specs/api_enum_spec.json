  "schemas": {
    "EasternFortuneResponse": {
      "type": "object",
      "properties": {
        "category": { "const": "eastern" },
        "chart": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "year": { "$ref": "#/schemas/Pillar" },
            "month": { "$ref": "#/schemas/Pillar" },
            "day": { "$ref": "#/schemas/Pillar" },
            "hour": { "$ref": "#/schemas/Pillar", "nullable": true }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "five_elements": {
              "type": "object",
              "properties": {
                "summary": { "type": "string" },
                "elements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": { "$ref": "#/enums/common/ElementCode" },
                      "label": { "type": "string" },
                      "value": { "type": "integer" },
                      "percent": { "type": "number" }
                    }
                  }
                },
                "strong": { "$ref": "#/enums/common/ElementCode" },
                "weak": { "$ref": "#/enums/common/ElementCode" }
              }
            },
            "yin_yang": {
              "type": "object",
              "properties": {
                "summary": { "type": "string" },
                "yin": { "type": "number" },
                "yang": { "type": "number" },
                "balance": { "$ref": "#/enums/common/YinYangBalance" }
              }
            },
            "ten_gods": {
              "type": "object",
              "properties": {
                "summary": { "type": "string" },
                "gods": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": { "$ref": "#/enums/eastern/TenGodCode" },
                      "label": { "type": "string" },
                      "group_code": { "$ref": "#/enums/eastern/TenGodGroupCode" },
                      "value": { "type": "integer" },
                      "percent": { "type": "number" }
                    }
                  }
                },
                "dominant": { "$ref": "#/enums/eastern/TenGodGroupCode" }
              }
            },
            "strength": { "type": "string" },
            "weakness": { "type": "string" }
          }
        },
        "summary": { "type": "string" },
        "message": { "type": "string" },
        "ui_hints": {
          "type": "object",
          "properties": {
            "badges": { "type": "array", "items": { "type": "string" } },
            "recommend_chart": { "$ref": "#/enums/common/ChartType" },
            "highlight": {
              "type": "object",
              "properties": {
                "day_master": { "$ref": "#/enums/eastern/PillarKey" },
                "strong_element": { "$ref": "#/enums/common/ElementCode" },
                "weak_element": { "$ref": "#/enums/common/ElementCode" }
              }
            }
          }
        },
        "lucky": {
          "type": "object",
          "properties": {
            "color": { "type": "string" },
            "color_code": { "type": "string", "nullable": true },
            "number": { "type": "string" },
            "item": { "type": "string" },
            "direction": { "type": "string" },
            "direction_code": { "$ref": "#/enums/common/DirectionCode", "nullable": true },
            "place": { "type": "string" }
          }
        }
      }
    },

    "Pillar": {
      "type": "object",
      "properties": {
        "gan": { "type": "string", "description": "한자 (甲)" },
        "gan_code": { "$ref": "#/enums/eastern/CheonGanCode" },
        "ji": { "type": "string", "description": "한자 (子)" },
        "ji_code": { "$ref": "#/enums/eastern/JiJiCode" },
        "element_code": { "$ref": "#/enums/common/ElementCode" },
        "ten_god_code": { "$ref": "#/enums/eastern/TenGodCode" }
      }
    },

    "WesternFortuneResponse": {
      "type": "object",
      "properties": {
        "category": { "const": "western" },
        "chart": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "sun": { "$ref": "#/schemas/BigThree" },
            "moon": { "$ref": "#/schemas/BigThree" },
            "rising": { "$ref": "#/schemas/BigThree" },
            "planets": { "type": "array", "items": { "$ref": "#/schemas/PlanetPlacement" } },
            "houses": { "type": "array", "items": { "$ref": "#/schemas/HouseInfo" } }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "elements": {
              "type": "object",
              "properties": {
                "summary": { "type": "string" },
                "distribution": { "type": "array" },
                "dominant": { "$ref": "#/enums/western/ZodiacElement" }
              }
            },
            "modality": {
              "type": "object",
              "properties": {
                "summary": { "type": "string" },
                "distribution": { "type": "array" },
                "dominant": { "$ref": "#/enums/western/ZodiacModality" }
              }
            },
            "aspects": {
              "type": "object",
              "properties": {
                "summary": { "type": "string" },
                "major_aspects": { "type": "array" }
              }
            },
            "strength": { "type": "string" },
            "weakness": { "type": "string" }
          }
        },
        "summary": { "type": "string" },
        "message": { "type": "string" },
        "ui_hints": {
          "type": "object",
          "properties": {
            "badges": { "type": "array", "items": { "type": "string" } },
            "recommend_chart": { "$ref": "#/enums/common/ChartType" },
            "highlight": {
              "type": "object",
              "properties": {
                "sun_sign": { "$ref": "#/enums/western/ZodiacCode" },
                "moon_sign": { "$ref": "#/enums/western/ZodiacCode" },
                "rising_sign": { "$ref": "#/enums/western/ZodiacCode" },
                "dominant_planet": { "$ref": "#/enums/western/PlanetCode" }
              }
            }
          }
        },
        "lucky": {
          "type": "object",
          "properties": {
            "day": { "type": "string" },
            "day_code": { "$ref": "#/enums/common/DayCode", "nullable": true },
            "color": { "type": "string" },
            "color_code": { "type": "string", "nullable": true },
            "number": { "type": "string" },
            "stone": { "type": "string" },
            "planet": { "$ref": "#/enums/western/PlanetCode" }
          }
        }
      }
    },

    "BigThree": {
      "type": "object",
      "properties": {
        "sign_code": { "$ref": "#/enums/western/ZodiacCode" },
        "house_number": { "type": "integer", "nullable": true },
        "summary": { "type": "string" }
      }
    },

    "PlanetPlacement": {
      "type": "object",
      "properties": {
        "planet_code": { "$ref": "#/enums/western/PlanetCode" },
        "sign_code": { "$ref": "#/enums/western/ZodiacCode" },
        "house_number": { "type": "integer" },
        "degree": { "type": "number" },
        "minute": { "type": "integer" },
        "is_retrograde": { "type": "boolean" }
      }
    },

    "ChatResponse": {
      "type": "object",
      "properties": {
        "session_id": { "type": "string" },
        "turn": { "type": "integer" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "character": { "$ref": "#/enums/chat/CharacterCode" },
              "type": { "$ref": "#/enums/chat/MessageType" },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "debate_status": {
          "type": "object",
          "properties": {
            "is_consensus": { "type": "boolean" },
            "eastern_opinion": { "type": "string", "nullable": true },
            "western_opinion": { "type": "string", "nullable": true },
            "question": { "type": "string", "nullable": true }
          }
        },
        "ui_hints": {
          "type": "object",
          "properties": {
            "show_choice": { "type": "boolean" },
            "choices": {
              "type": "array",
              "nullable": true,
              "items": {
                "type": "object",
                "properties": {
                  "value": { "type": "integer", "enum": [1, 2] },
                  "character": { "$ref": "#/enums/chat/CharacterCode" },
                  "label": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },

  "endpoints": [
    { "method": "POST", "path": "/api/v1/fortune/eastern", "description": "동양 사주 분석" },
    { "method": "GET", "path": "/api/v1/fortune/eastern/enums", "description": "동양 Enum 목록" },
    { "method": "POST", "path": "/api/v1/fortune/western", "description": "서양 점성술 분석" },
    { "method": "GET", "path": "/api/v1/fortune/western/enums", "description": "서양 Enum 목록" },
    { "method": "POST", "path": "/api/v1/fortune/chat", "description": "티키타카 대화" },
    { "method": "POST", "path": "/api/v1/fortune/chat/stream", "description": "티키타카 SSE 스트리밍" },
    { "method": "GET", "path": "/api/v1/fortune/chat/characters", "description": "캐릭터 정보" }
  ]
}
